# Path to your Google Cloud service account JSON key file
GOOGLE_CLOUD_KEY_PATH=credentials/service_account.json

# GCP project ID (from Google Cloud Console)
GCP_PROJECT_ID=copies-qc

# BigQuery dataset (created automatically on first run)
BQ_DATASET=pn_report

# MoEngage API credentials (for automated daily runs — replaces manual CSV export)
# Find at: MoEngage → Settings → APIs → Data Export
MOENGAGE_APP_ID=your_app_id_here
MOENGAGE_SECRET_KEY=your_secret_key_here
# Data center: check your MoEngage dashboard URL
# India: api-01, US: api-02, EU: api-03
MOENGAGE_DATA_CENTER=api-01
